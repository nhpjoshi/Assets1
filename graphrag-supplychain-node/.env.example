# MongoDB Atlas connection string (Atlas UI -> Connect -> Drivers)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/

# Database name to use for this demo
MONGODB_DB=supplychain_graphrag

# Optional. If unset, the app falls back to an extractive answer
# built directly from the retrieved graph context (no LLM call).
ANTHROPIC_API_KEY=

# Embeddings: set ONE of the following two keys, not both.
#
# Option A - a key created directly at https://www.voyageai.com (dashboard ->
# API keys). Talks to https://api.voyageai.com/v1/embeddings.
VOYAGE_API_KEY=
#
# Option B - a "Model API Key" created in the Atlas UI (Organization -> Model
# API Keys, under "Voyage AI by MongoDB"). Talks to https://ai.mongodb.com/v1/embeddings
# instead. If you generated your key through Atlas rather than voyageai.com
# directly, use this variable, not VOYAGE_API_KEY - the two key types are not
# interchangeable.
MONGODB_MODEL_API_KEY=

# Voyage embedding model. voyage-3.5 is a strong general-purpose default
# (1024 dimensions). If you change this to a model with a different output
# size, also update EMBEDDING_DIMENSIONS in src/config.js and re-run ingestion.
EMBEDDING_MODEL=voyage-3.5
